<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.cms.model.testimonial.Testimonial"
           table="testimonials">

        <id name="id" column="id">
            <generator class="sequence"/>
        </id>

        <property name="witness"      column="witness"/>
        <property name="testimonial"  column="testimonial" not-null="true" length="300"/>
        <property name="rating"       column="rating" not-null="true"/>
        <property name="email"        column="email"/>
        <property name="state"        column="state" type="com.cms.model.testimonial.enums.StateTestimonial"/>
        <property name="createdAt"    column="created_at"/>

        <many-to-one name="embed"
                     class="com.cms.model.embeds.Embed"
                     column="embed_id"
                     cascade="merge"
                     not-null="true"/>

        <component name="media" class="com.cms.model.testimonial.Media">
            <property name="id"           column="media_id"/>
            <property name="url"          column="image_url"/>
            <property name="publicId"     column="image_public_id"/>
            <property name="videoUrl"     column="video_url"/>
            <property name="videoId"      column="video_id"/>
            <property name="videoTitle"   column="video_title"/>
            <property name="thumbnailUrl" column="thumbnail_url"/>
            <property name="channelName"  column="channel_name"/>
        </component>

        <many-to-one name="category"
                     class="com.cms.model.testimonial.Category"
                     column="category_id"
                     lazy="false"
                     cascade="merge"/>

        <many-to-one name="admin"
                     class="com.cms.model.user.impl.admin.Admin"
                     column="admin_id"
                     not-null="true"
                     cascade="none"/>

        <bag name="tags" table="testimonial_tags" cascade="merge" lazy="false">
            <key column="testimonial_id"/>
            <many-to-many class="com.cms.model.testimonial.Tag" column="tag_id"/>
        </bag>

    </class>

</hibernate-mapping>