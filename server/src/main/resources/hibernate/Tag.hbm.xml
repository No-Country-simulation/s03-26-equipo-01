<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.cms.model.testimonial.Tag" table="tags">

        <id name="id" column="id">
            <generator class="identity"/>
        </id>

        <property name="name"      column="name"       not-null="true" unique="true"/>
        <property name="slug"      column="slug"       not-null="true" unique="true"/>
        <property name="active"    column="is_active"  not-null="true"/>
        <property name="createdAt" column="created_at" not-null="true" update="false"/>

        <many-to-one name="creator"
                     class="com.cms.model.user.impl.admin.Admin"
                     column="created_by"
                     not-null="false"
                     cascade="persist,merge"
                    />

        <set name="testimonials" table="testimonial_tags" fetch="select" lazy="true" cascade="persist,merge">
            <key column="tag_id"/>
            <many-to-many class="com.cms.model.testimonial.Testimonial" column="testimonial_id"/>
        </set>

    </class>

</hibernate-mapping>