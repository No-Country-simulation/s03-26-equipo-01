<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.cms.model.user.User"
           table="users"
           abstract="true"
           discriminator-value="USER">

        <id name="id" column="id">
            <generator class="sequence"/>
        </id>

        <discriminator column="role" type="string"/>

        <property name="email" column="email" unique="true"/>
        <property name="password" column="password"/>
        <property name="firstName" column="first_name"/>
        <property name="lastName" column="last_name"/>
        <property name="enabled" column="enabled"/>

        <subclass name="com.cms.model.user.impl.admin.Admin"
                  discriminator-value="ADMIN">

            <bag name="embeds"
                 inverse="true"
                 lazy="false">
                <key column="admin_id"/>
                <one-to-many class="com.cms.model.embeds.Embed"/>
            </bag>

            <bag name="tags"
                 inverse="true"
                 lazy="false">
                <key column="created_by"/>
                <one-to-many class="com.cms.model.testimonial.Tag"/>
            </bag>

            <bag name="editors" inverse="true" lazy="false">
                <key column="created_by"/>
                <one-to-many class="com.cms.model.user.impl.Editor"/>
            </bag>

            <bag name="categories" inverse="true" lazy="false">
                <key column="created_by"/>
                <one-to-many class="com.cms.model.testimonial.Category"/>
            </bag>

            <one-to-one name="apiKey"
                        class="com.cms.model.user.impl.admin.ApiKey"
                        property-ref="admin"
                        cascade="all"
                        lazy="false"/>


        </subclass>

        <subclass name="com.cms.model.user.impl.Editor"
                  discriminator-value="EDITOR">

            <many-to-one name="createdBy"
                         class="com.cms.model.user.impl.admin.Admin"
                         column="created_by"
                         not-null="false"
                         cascade="none"/>
        </subclass>

    </class>

</hibernate-mapping>