<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.cms.model.user.impl.admin.ApiKey" table="api_keys">

        <id name="id" column="id">
            <generator class="sequence"/>
        </id>

        <property name="keyHash"    column="key_hash"    not-null="true"/>
        <property name="prefix"     column="prefix"      not-null="true"/>
        <property name="active"     column="active"      not-null="true"/>

        <many-to-one name="admin"
                     class="com.cms.model.user.impl.admin.Admin"
                     column="admin_id"
                     not-null="true"
                     unique="true"
                     cascade="none"/>

    </class>

</hibernate-mapping>